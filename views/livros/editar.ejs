<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Livros</title>
</head>
<body>
    <h1>Criar Livros</h1>
    <a href="/livros"> Voltar para a lista de livros</a>
    <form action="/livros/<%= livro.id%>" method="post">
        <label for="titulo">Título:</label>
        <input type="text" id="titulo" name="titulo" value="<%= livro.titulo %>" required>
        
        <label for="autor">Autor:</label>
        <input type="text" id="autor" name="autor" value="<%= livro.autor %>" required>
        
        <button type="submit">Atualizar informações livro</button>
        
    
</body>
</html>